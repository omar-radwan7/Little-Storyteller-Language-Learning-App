  "order": 1,
  "title": "Personal Pronouns",
  "description": "How to say me, you, him, and her in German! Plus, some useful first words.",
  "explanation": "Personal pronouns are the blocks of any sentence. Before you can say 'I drink' or 'I want', you need to know how to say 'I'! Here are the 1st, 2nd, and 3rd person building blocks.",
  "tables": [
    {
      "title": "German Personal Pronouns",
      "headers": ["Person(s)", "German Word", "Meaning"],
      "rows": [
        ["I", "ich", "me!"],
        ["We", "wir", "me and friends"],
        ["You", "du", "one friend"],
        ["You all", "ihr", "group of friends"],
        ["He/She/It", "er / sie / es", "him/her/it"],
        ["They", "sie", "them"],
        ["You (Formal)", "Sie", "Boss / Stranger"]
      ],
      "note": "Notice 'sie' can mean 'she' AND 'they'—just look at the context!"
    }
  ],
  "deep_notes": [
    {
      "title": "A few useful words!",
      "text": "1. trinke (drink)\n2. esse (eat)\n3. komme (come)\n4. lerne (learn)."
    }
  ],
  "examples": [
    {
      "german": "Ich trinke Wasser.",
      "english": "I drink water.",
      "explanation": "'Ich' (I) + 'trinke' (drink) + 'Wasser' (water)."
    },
    {
      "german": "Wir essen Brot.",
      "english": "We eat bread.",
      "explanation": "We = 'wir'."
    },
    {
      "german": "Lernst du Deutsch?",
      "english": "Are you learning German?",
      "explanation": "For a question, put the verb 'lernst' first!"
    },
    {
      "german": "Sie kommen aus Berlin.",
      "english": "They come from Berlin."
    }
  ],
  "exercises": [
