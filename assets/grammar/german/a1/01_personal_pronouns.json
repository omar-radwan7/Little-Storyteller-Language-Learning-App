      "type": "fill_blank",
      "text": "____ trinke Wasser.",
      "options": ["er", "du", "ich", "wir"],
      "correctAnswer": "ich",
      "explanation": "ich uses the -e ending (trinke)!"
    },
    {
      "type": "multiple_choice",
      "question": "Welches Pronomen nutzt man für sich selbst?",
      "options": ["ich", "du", "er", "wir"],
      "correctAnswer": "ich",
      "explanation": "ich = I!"
    },
    {
      "type": "fill_blank",
      "text": "____ lernt Deutsch.",
